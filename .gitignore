outputs/direct_ub_psi_ablation/

# M-axis pilot (gaussian vs subsample M, often with dct), scripts/run_direct_ub_dct_m_pilot.sh
outputs/direct_ub_dct_m_ablation/

# Direct UB measurement-noise robustness (scripts/run_direct_ub_dct_subsample_noise_robustness.sh)
outputs/direct_ub_robustness/

# Robustness Phase 3 sweep outputs (large; regenerate with run_robustness_phase3_sweep.py)
outputs/robustness_phase3/

# Generated robustness PNG tree under paper/ (large; copy from outputs after runs)
paper/figures/robustness_phase3/

